<?xml version="1.0"?>
<robot name="pragati_robot">
  
  <!-- Base link -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.1 0.1 0.1"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="1.0"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>
  </link>

  <!-- Yanthra origin link - the main reference frame -->
  <link name="yanthra_link">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.02"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 1.0 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>

  <!-- Joint2 link (prismatic - height/vertical movement) -->
  <link name="joint2">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.2"/>
      </geometry>
      <material name="red">
        <color rgba="1.0 0.0 0.0 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.5" ixy="0.0" ixz="0.0" iyy="0.5" iyz="0.0" izz="0.5"/>
    </inertial>
  </link>

  <!-- Joint3 link (revolute - phi/vertical rotation) -->
  <link name="joint3">
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.15"/>
      </geometry>
      <material name="green">
        <color rgba="0.0 1.0 0.0 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.3" ixy="0.0" ixz="0.0" iyy="0.3" iyz="0.0" izz="0.3"/>
    </inertial>
  </link>

  <!-- Link3 - frame used for coordinate transformations -->
  <link name="link3">
    <visual>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
      <material name="yellow">
        <color rgba="1.0 1.0 0.0 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <!-- Joint4 link (revolute - theta/horizontal rotation) -->
  <link name="joint4">
    <visual>
      <geometry>
        <cylinder radius="0.025" length="0.15"/>
      </geometry>
      <material name="cyan">
        <color rgba="0.0 1.0 1.0 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.3" ixy="0.0" ixz="0.0" iyy="0.3" iyz="0.0" izz="0.3"/>
    </inertial>
  </link>

  <!-- Link4 - frame used for coordinate transformations -->
  <link name="link4">
    <visual>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
      <material name="magenta">
        <color rgba="1.0 0.0 1.0 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <!-- Joint5 link (prismatic - r/radial extension) -->
  <link name="joint5">
    <visual>
      <geometry>
        <cylinder radius="0.02" length="0.3"/>
      </geometry>
      <material name="orange">
        <color rgba="1.0 0.5 0.0 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.2" ixy="0.0" ixz="0.0" iyy="0.2" iyz="0.0" izz="0.2"/>
    </inertial>
  </link>

  <!-- Link5 - frame used for coordinate transformations -->
  <link name="link5">
    <visual>
      <geometry>
        <sphere radius="0.01"/>
      </geometry>
      <material name="white">
        <color rgba="1.0 1.0 1.0 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.01"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
    </inertial>
  </link>

  <!-- Link5 origin - end effector reference frame -->
  <link name="link5_origin">
    <visual>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
      <material name="purple">
        <color rgba="0.5 0.0 0.5 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.05"/>
      <inertia ixx="0.05" ixy="0.0" ixz="0.0" iyy="0.05" iyz="0.0" izz="0.05"/>
    </inertial>
  </link>

  <!-- Camera link (if camera is enabled) -->
  <link name="camera_link">
    <visual>
      <geometry>
        <box size="0.05 0.03 0.02"/>
      </geometry>
      <material name="black">
        <color rgba="0.0 0.0 0.0 1"/>
      </material>
    </visual>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>

  <!-- JOINTS -->

  <!-- Base to yanthra_link -->
  <joint name="base_to_yanthra" type="fixed">
    <parent link="base_link"/>
    <child link="yanthra_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Joint2 - Prismatic (height control) -->
  <joint name="joint2_joint" type="prismatic">
    <parent link="yanthra_link"/>
    <child link="joint2"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="0.01" upper="1.0" effort="100" velocity="2.0"/>
  </joint>

  <!-- Joint3 - Revolute (phi - vertical rotation) -->
  <joint name="joint3_joint" type="revolute">
    <parent link="joint2"/>
    <child link="joint3"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14159" upper="3.14159" effort="50" velocity="2.0"/>
  </joint>

  <!-- Link3 reference frame -->
  <joint name="joint3_to_link3" type="fixed">
    <parent link="joint3"/>
    <child link="link3"/>
    <origin xyz="0 0 0.075" rpy="0 0 0"/>
  </joint>

  <!-- Joint4 - Revolute (theta - horizontal rotation) -->
  <joint name="joint4_joint" type="revolute">
    <parent link="link3"/>
    <child link="joint4"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-3.14159" upper="3.14159" effort="50" velocity="2.0"/>
  </joint>

  <!-- Link4 reference frame -->
  <joint name="joint4_to_link4" type="fixed">
    <parent link="joint4"/>
    <child link="link4"/>
    <origin xyz="0 0 0.075" rpy="0 0 0"/>
  </joint>

  <!-- Joint5 - Prismatic (r - radial extension) -->
  <joint name="joint5_joint" type="prismatic">
    <parent link="link4"/>
    <child link="joint5"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="0.162" upper="0.601" effort="30" velocity="1.1"/>
  </joint>

  <!-- Link5 reference frame -->
  <joint name="joint5_to_link5" type="fixed">
    <parent link="joint5"/>
    <child link="link5"/>
    <origin xyz="0.15 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Link5 origin - end effector frame -->
  <joint name="link5_to_origin" type="fixed">
    <parent link="link5"/>
    <child link="link5_origin"/>
    <origin xyz="0.085 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Camera link (mounted on link5_origin) -->
  <joint name="camera_mount" type="fixed">
    <parent link="link5_origin"/>
    <child link="camera_link"/>
    <origin xyz="0.02 0 0.01" rpy="0 0 0"/>
  </joint>

</robot>