# Pragati ROS2 Configuration File
# ================================
# Copy this file to config.env and customize for your setup
#
# Usage:
#   cp config.env.example config.env
#   ./scripts/config_manager.sh   # Interactive setup
#   # OR manually edit config.env
#
# This file is automatically sourced by build.sh and sync.sh
# Environment variables and command-line arguments override these settings

# ============================================================================
# Default Target Configuration
# ============================================================================
# These are used when no profile is specified

# Target device IP address (required)
RPI_IP=192.168.137.253

# SSH username on target device (default: ubuntu)
RPI_USER=ubuntu

# SSH key path (optional - uses default SSH key if not set)
# RPI_SSH_KEY=~/.ssh/id_rsa

# Target directory on remote device
# Default: /home/$RPI_USER/pragati_ros2
RPI_TARGET_DIR=~/pragati_ros2

# ============================================================================
# Cross-Compilation Settings
# ============================================================================

# Sysroot path for cross-compilation
# WSL ext4:  ~/rpi-sysroot (recommended - fastest I/O)
# Ubuntu:    /media/rpi-sysroot
# Custom:    /path/to/your/sysroot
RPI_SYSROOT=~/rpi-sysroot

# Default packages to build (space-separated)
# Leave empty to build all packages
# BUILD_PACKAGES="motor_control_ros2 cotton_detection_ros2"
BUILD_PACKAGES=

# ============================================================================
# Named Profiles for Multiple Targets
# ============================================================================
# Define multiple RPi targets with unique names
# Format: <NAME>_IP, <NAME>_USER, <NAME>_TARGET_DIR, <NAME>_SSH_KEY
#
# Examples:
#   Profile name: rpi1 → use with: ./sync.sh --profile rpi1
#   Profile name: rpi2 → use with: ./build.sh rpi --profile rpi2

# Profile: rpi1 (Main test device)
RPI1_IP=192.168.137.253
RPI1_USER=ubuntu
RPI1_TARGET_DIR=~/pragati_ros2
# RPI1_SSH_KEY=~/.ssh/rpi1_key

# Profile: rpi2 (Backup device)
# RPI2_IP=192.168.137.254
# RPI2_USER=ubuntu
# RPI2_TARGET_DIR=~/pragati_ros2
# RPI2_SSH_KEY=~/.ssh/rpi2_key

# Profile: rpi3 (Development device)
# RPI3_IP=192.168.1.100
# RPI3_USER=pi
# RPI3_TARGET_DIR=~/ros2_ws
# RPI3_SSH_KEY=~/.ssh/rpi3_key

# Profile: vehicle1 (Cotton picker #1)
# VEHICLE1_IP=192.168.137.10
# VEHICLE1_USER=ubuntu
# VEHICLE1_TARGET_DIR=~/pragati_ros2

# Profile: vehicle2 (Cotton picker #2)
# VEHICLE2_IP=192.168.137.11
# VEHICLE2_USER=ubuntu
# VEHICLE2_TARGET_DIR=~/pragati_ros2

# List all profile names for batch operations (comma-separated)
# Used with: ./sync.sh --all-profiles
# ALL_PROFILES="rpi1,rpi2,rpi3"
ALL_PROFILES=

# ============================================================================
# Build Configuration
# ============================================================================

# Default build mode: standard, fast, full, rpi (cross-compile)
# BUILD_MODE=fast

# Number of parallel build jobs
# Auto-detected if not set (nproc - 2, minimum 2)
# PARALLEL_WORKERS=4

# Clean build by default (true/false)
# CLEAN_BUILD=false

# ============================================================================
# Sync Configuration
# ============================================================================

# Default sync mode: default, all, source, quick
# SYNC_MODE=default

# Exclude patterns for rsync (space-separated)
# SYNC_EXCLUDE="*.log *.tmp build/ install/ log/"

# ============================================================================
# WSL-Specific Settings
# ============================================================================
# Auto-detected, but can be overridden

# Force WSL mode (true/false) - auto-detected if not set
# FORCE_WSL=false

# Windows SSH path for hotspot connectivity
# WINDOWS_SSH_PATH=/mnt/c/WINDOWS/System32/OpenSSH/ssh.exe

# ============================================================================
# Advanced Settings
# ============================================================================

# ROS2 distribution (default: humble)
# ROS_DISTRO=humble

# Verbose output (true/false)
# VERBOSE=false

# Dry run mode - show what would be done without executing
# DRY_RUN=false

# Backup before sync (true/false)
# BACKUP_BEFORE_SYNC=false

# ============================================================================
# Notes
# ============================================================================
# - Lines starting with # are comments
# - Uncomment (remove #) to activate a setting
# - Values with spaces should be quoted: VAR="value with spaces"
# - Paths with ~ are expanded to home directory
# - Environment variables override these settings
# - Command-line arguments override everything
#
# Quick Start:
#   1. Copy this file: cp config.env.example config.env
#   2. Edit config.env and set RPI_IP at minimum
#   3. Run: ./build.sh rpi -p motor_control_ros2
#   4. Run: ./sync.sh
#
# For multiple devices:
#   1. Define profiles above (RPI1_IP, RPI2_IP, etc.)
#   2. Use: ./sync.sh --profile rpi1
#   3. Or deploy to all: ./sync.sh --all-profiles
