# Doxyfile for Pragati ROS2 Project

PROJECT_NAME           = "Pragati ROS2"
PROJECT_NUMBER         = 1.0
PROJECT_BRIEF          = "Agricultural Robotics Platform for Autonomous Cotton Harvesting"
OUTPUT_DIRECTORY       = docs/api
CREATE_SUBDIRS         = YES
ALLOW_UNICODE_NAMES    = YES

# Input configuration
INPUT                  = src \
                         docs/README.md
RECURSIVE              = YES
FILE_PATTERNS          = *.cpp \
                         *.hpp \
                         *.h \
                         *.py \
                         *.md
EXCLUDE                = build \
                         install \
                         log \
                         */test/* \
                         */deprecated/* \
                         */archive/*

# Output formats
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
GENERATE_XML           = YES
HTML_OUTPUT            = html
XML_OUTPUT             = xml

# HTML output options
HTML_TIMESTAMP         = YES
HTML_DYNAMIC_SECTIONS  = YES
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO
HTML_COLORSTYLE        = LIGHT

# Documentation extraction
EXTRACT_ALL            = YES
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = YES
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
SHOW_INCLUDE_FILES     = YES
INLINE_SOURCES         = NO
SOURCE_BROWSER         = YES

# Diagrams and graphs
HAVE_DOT               = YES
DOT_NUM_THREADS        = 4
UML_LOOK               = YES
TEMPLATE_RELATIONS     = YES
INCLUDE_GRAPH          = YES
INCLUDED_BY_GRAPH      = YES
CALL_GRAPH             = YES
CALLER_GRAPH           = YES
GRAPHICAL_HIERARCHY    = YES
DIRECTORY_GRAPH        = YES
DOT_IMAGE_FORMAT       = svg
INTERACTIVE_SVG        = YES
DOT_GRAPH_MAX_NODES    = 100
MAX_DOT_GRAPH_DEPTH    = 3

# Preprocessing
ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
SEARCH_INCLUDES        = YES
INCLUDE_PATH           = src/motor_control_ros2/include \
                         src/yanthra_move/include \
                         src/cotton_detection_ros2/include

# Warnings
QUIET                  = NO
WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = NO

# External references
GENERATE_TAGFILE       = docs/api/pragati_ros2.tag
ALLEXTERNALS           = NO
EXTERNAL_GROUPS        = YES
EXTERNAL_PAGES         = YES
