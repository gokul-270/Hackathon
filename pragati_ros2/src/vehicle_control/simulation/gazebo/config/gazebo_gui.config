<?xml version="1.0" ?>
<!--
  Gazebo GUI configuration with camera view presets for veh1
-->
<gui fullscreen="0">

  <!-- 3D scene -->
  <plugin filename="MinimalScene" name="3D View">
    <gz-gui>
      <title>3D View</title>
      <property type="bool" key="showTitleBar">false</property>
      <property type="string" key="state">docked</property>
    </gz-gui>

    <engine>ogre</engine>
    <scene>scene</scene>
    <ambient_light>0.4 0.4 0.4</ambient_light>
    <background_color>0.8 0.8 0.8</background_color>
    
    <!-- Initial camera pose: Zoomed out isometric view to see vehicle and field -->
    <camera_pose>-10.0 15.0 25.0 0 0.8 -1.57</camera_pose>
  </plugin>

  <!-- Camera controls plugin -->
  <plugin filename="GzSceneManager" name="Scene Manager">
    <gz-gui>
      <property type="bool" key="showTitleBar">false</property>
      <property type="string" key="state">floating</property>
      <property type="double" key="height">0</property>
      <property type="double" key="width">0</property>
    </gz-gui>
  </plugin>

  <plugin filename="InteractiveViewControl" name="Interactive View Control">
    <gz-gui>
      <property type="bool" key="showTitleBar">false</property>
    </gz-gui>
  </plugin>

  <!-- World control -->
  <plugin filename="WorldControl" name="World control">
    <gz-gui>
      <title>World control</title>
      <property type="bool" key="showTitleBar">false</property>
      <property type="bool" key="resizable">false</property>
      <property type="double" key="height">72</property>
      <property type="double" key="width">121</property>
      <property type="double" key="z">1</property>
      <property type="string" key="state">floating</property>
      <anchors target="3D View">
        <line own="left" target="left"/>
        <line own="bottom" target="bottom"/>
      </anchors>
    </gz-gui>

    <play_pause>true</play_pause>
    <step>true</step>
    <start_paused>true</start_paused>
  </plugin>

  <!-- World stats -->
  <plugin filename="WorldStats" name="World stats">
    <gz-gui>
      <title>World stats</title>
      <property type="bool" key="showTitleBar">false</property>
      <property type="bool" key="resizable">false</property>
      <property type="double" key="height">110</property>
      <property type="double" key="width">290</property>
      <property type="double" key="z">1</property>
      <property type="string" key="state">floating</property>
      <anchors target="3D View">
        <line own="right" target="right"/>
        <line own="bottom" target="bottom"/>
      </anchors>
    </gz-gui>

    <sim_time>true</sim_time>
    <real_time>true</real_time>
    <real_time_factor>true</real_time_factor>
    <iterations>true</iterations>
  </plugin>

  <!-- Entity tree -->
  <plugin filename="EntityTree" name="Entity tree">
    <gz-gui>
      <property type="string" key="state">docked</property>
    </gz-gui>
  </plugin>

  <!-- Component inspector -->
  <plugin filename="ComponentInspector" name="Component inspector">
    <gz-gui>
      <property type="string" key="state">docked</property>
    </gz-gui>
  </plugin>

  <!-- Transform control for moving objects -->
  <plugin filename="TransformControl" name="Transform control">
    <gz-gui>
      <property type="string" key="state">docked</property>
    </gz-gui>
  </plugin>

  <!-- View angle plugin - provides preset view buttons -->
  <plugin filename="ViewAngle" name="View Angle">
    <gz-gui>
      <property type="string" key="state">docked</property>
      <property type="double" key="height">300</property>
    </gz-gui>
    
    <!-- Target to look at -->
    <target>0 0 0.5</target>
  </plugin>

  <!-- Tape measure tool -->
  <plugin filename="TapeMeasure" name="Tape measure">
    <gz-gui>
      <property type="string" key="state">docked</property>
    </gz-gui>
  </plugin>

  <!-- Camera tracking (required by other plugins) -->
  <plugin filename="CameraTracking" name="Camera Tracking">
    <gz-gui>
      <property type="bool" key="showTitleBar">false</property>
      <property key="state" type="string">floating</property>
      <property key="width" type="double">5</property>
      <property key="height" type="double">5</property>
    </gz-gui>
  </plugin>

  <!-- Marker manager (required by other plugins) -->
  <plugin filename="MarkerManager" name="Marker manager">
    <gz-gui>
      <property type="bool" key="showTitleBar">false</property>
      <property key="state" type="string">floating</property>
      <property key="width" type="double">5</property>
      <property key="height" type="double">5</property>
    </gz-gui>
  </plugin>

  <!-- Select entities -->
  <plugin filename="SelectEntities" name="Select Entities">
    <gz-gui>
      <property type="bool" key="showTitleBar">false</property>
      <property key="state" type="string">floating</property>
      <property key="width" type="double">5</property>
      <property key="height" type="double">5</property>
    </gz-gui>
  </plugin>

  <!-- Visualization capabilities (required by VideoRecorder) -->
  <plugin filename="VisualizationCapabilities" name="Visualization Capabilities">
    <gz-gui>
      <property type="bool" key="showTitleBar">false</property>
      <property key="state" type="string">floating</property>
      <property key="width" type="double">5</property>
      <property key="height" type="double">5</property>
    </gz-gui>
  </plugin>

  <!-- Video recorder plugin for programmatic recording -->
  <plugin filename="VideoRecorder" name="VideoRecorder">
    <gz-gui>
      <property type="string" key="state">docked</property>
    </gz-gui>
  </plugin>

</gui>
