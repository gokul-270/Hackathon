    <joint name="axial-front_Revolute-10" type="continuous">
        <origin xyz="4.806000000002087e-05 -0.00799999999999999 -0.3992317399999999" rpy="-1.5707963267948966 -4.8862532784603164e-32 -1.5707963267948966" />
        <parent link="axial-front" />
        <child link="front-wheel" />
        <axis xyz="-1.0 -4.974508036802331e-32 -0.0" />
        <dynamics damping="0.5" friction="0.1" />
        <limit effort="500" velocity="20.0" />
    </joint>
    
    <!-- Kinematic Origin Joint - Defines Robot Center -->
    <!-- From base-v1 (at right wheel 0,0,0) to robot center (0.65, 0.9, 0) -->
    <!-- base-v1 at right wheel: (0, 0, 0)
         rear axle center: (0, 0.9) = midpoint of left(0,1.8) and right(0,0)
         front wheel: (1.3, 0.9)
         robot center: (0.65, 0.9) = midpoint of front and rear axle -->
    <joint name="base-v1_to_origin" type="fixed">
        <origin xyz="0.65 0.0 0.9" rpy="-1.5707963267948966 0.0 0.0" />
        <parent link="base-v1" />
        <child link="origin" />
    </joint>
    
    <joint name="base-v1_Rigid-11" type="fixed">
        <origin xyz="1.2999999984237778 -1.6662377078091596e-09 0.900000000152554" rpy="-1.5707963267948961 -9.057424948943961e-16 -2.0816681711721774e-16" />
        <parent link="base-v1" />
        <child link="base-plate-front" />
    </joint>
    <joint name="base-v1_Rigid-12" type="fixed">
        <origin xyz="-1.5762218197323818e-09 -1.6662379209719803e-09 1.5254542518050585e-10" rpy="-1.5707963267948961 -9.057424948943961e-16 -2.0816681711721774e-16" />
        <parent link="base-v1" />
        <child link="base-plate-right" />
    </joint>
    <joint name="base-v1_Rigid-13" type="fixed">
        <origin xyz="-1.5762245908490514e-09 -1.6662371393749709e-09 1.8000000001525605" rpy="1.570796326794897 -9.057424948943961e-16 -2.0816681711721774e-16" />
        <parent link="base-v1" />
        <child link="base-plate-left" />
    </joint>
    <joint name="base-plate-front_Revolute-14" type="revolute">
        <origin xyz="0.105 0.01 -0.09700000000000003" rpy="2.3948350467888256e-63 2.237605975518999e-31 0.0" />
        <parent link="base-plate-front" />
        <child link="axial-front" />
        <axis xyz="-2.3590385388993773e-31 0.0 1.0" />
        <limit lower="-1.570796" upper="1.570796" effort="100" velocity="2.0" />
        <dynamics damping="1.0" friction="0.5" />
    </joint>
    <joint name="base-plate-right_Revolute-18" type="revolute">
        <origin xyz="-0.10500000000000002 -0.01 -0.09699999999999996" rpy="3.141592653589793 -7.18779982929554e-32 2.189528850507527e-47" />
        <parent link="base-plate-right" />
        <child link="axial-right" />
        <axis xyz="-5.973474195491757e-32 0.0 0.9999999999999999" />
        <limit lower="-1.570796" upper="1.570796" effort="100" velocity="2.0" />
        <dynamics damping="1.0" friction="0.5" />
    </joint>
    <joint name="axial-right_Revolute-19" type="continuous">
        <origin xyz="4.80600000000031e-05 -0.09219303999999993 0.3999984099999999" rpy="1.5707963267948966 -1.4612587475429843e-32 1.5707963267948966" />
        <parent link="axial-right" />
        <child link="right-wheel" />
        <axis xyz="-1.0 1.1276818820434178e-31 -7.888609052210118e-31" />
        <dynamics damping="0.5" friction="0.1" />
        <limit effort="500" velocity="20.0" />
    </joint>
    <joint name="base-plate-left_Revolute-20" type="revolute">
        <origin xyz="-0.10500000000000002 0.01 0.09700000000000003" rpy="-3.141592653589793 -2.9112058178301707e-31 1.9721522630525295e-31" />
        <parent link="base-plate-left" />
        <child link="axial-left" />
        <axis xyz="-3.032638381210549e-31 0.0 1.0" />
        <limit lower="-1.570796" upper="1.570796" effort="100" velocity="2.0" />
        <dynamics damping="1.0" friction="0.5" />
    </joint>
    <joint name="axial-left_Revolute-21" type="continuous">
        <origin xyz="4.80600000000031e-05 0.09219303999999993 -0.3992317399999999" rpy="-1.5707963267948966 -1.812345601166459e-34 -1.5707963267948966" />
        <parent link="axial-left" />
        <child link="left-wheel" />
        <axis xyz="-1.0000000000000002 3.370377402677343e-32 9.860761315262648e-32" />
        <dynamics damping="0.5" friction="0.1" />
        <limit effort="500" velocity="20.0" />
    </joint>

    <!-- ==================== SENSOR LINKS ==================== -->
    
    <!-- IMU Sensor -->
    <link name="imu_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.001"/>
            <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" iyz="0" ixz="0"/>
        </inertial>
    </link>
    
    <joint name="imu_joint" type="fixed">
        <origin xyz="0.65 0.0 0.9" rpy="-1.5707963267948966 0.0 0.0"/>
        <parent link="base-v1"/>
        <child link="imu_link"/>
    </joint>
    
    <gazebo reference="imu_link">
        <sensor name="imu_sensor" type="imu">
            <always_on>true</always_on>
            <update_rate>100</update_rate>
            <topic>imu</topic>
            <imu>
                <angular_velocity>
                    <x><noise type="none"/></x>
                    <y><noise type="none"/></y>
                    <z><noise type="none"/></z>
                </angular_velocity>
                <linear_acceleration>
                    <x><noise type="none"/></x>
                    <y><noise type="none"/></y>
                    <z><noise type="none"/></z>
                </linear_acceleration>
            </imu>
        </sensor>
    </gazebo>

    <!-- NavSat/GPS Sensor -->
    <link name="navsat_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.001"/>
            <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" iyz="0" ixz="0"/>
        </inertial>
    </link>
    
    <joint name="navsat_joint" type="fixed">
        <origin xyz="0.65 0.0 1.2" rpy="-1.5707963267948966 0.0 0.0"/>
        <parent link="base-v1"/>
        <child link="navsat_link"/>
    </joint>
    
    <gazebo reference="navsat_link">
        <sensor name="navsat_sensor" type="navsat">
            <always_on>true</always_on>
            <update_rate>10</update_rate>
            <topic>navsat</topic>
        </sensor>
    </gazebo>

    <!-- Camera Sensor (front-facing, simulating OAK-D Lite) -->
    <link name="camera_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.001"/>
            <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" iyz="0" ixz="0"/>
        </inertial>
    </link>
    
    <link name="camera_optical_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.001"/>
            <inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" iyz="0" ixz="0"/>
        </inertial>
    </link>
    
    <!-- Camera mounted in front of front wheel, facing forward with 15° downward tilt -->
    <!-- base-v1 Z-axis = world lateral; X-forward, Y-up in Gazebo after roll correction -->
    <!-- Position: x=1.55 (ahead of front wheel at 1.4), z=0.9 (centerline), y height handled by rpy -->
    <joint name="camera_joint" type="fixed">
        <origin xyz="1.55 -0.25 0.9" rpy="-1.5707963267948966 0.0 -0.2618"/>
        <parent link="base-v1"/>
        <child link="camera_link"/>
    </joint>
    
    <joint name="camera_optical_joint" type="fixed">
        <origin xyz="0 0 0" rpy="-1.5707963267948966 0.0 -1.5707963267948966"/>
        <parent link="camera_link"/>
        <child link="camera_optical_link"/>
    </joint>
    
    <gazebo reference="camera_link">
        <sensor name="camera_sensor" type="camera">
            <always_on>true</always_on>
            <update_rate>10</update_rate>
            <visualize>true</visualize>
            <topic>front_camera</topic>
            <camera>
                <horizontal_fov>1.2740903539558606</horizontal_fov>
                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.1</near>
                    <far>100</far>
                </clip>
            </camera>
        </sensor>
    </gazebo>
</robot>
