<?xml version='1.0' encoding='utf-8'?>
<robot name="vehicle">
    <!-- Gazebo Plugins -->
    <gazebo>
        <!-- Joint State Publisher -->
        <plugin filename="gz-sim-joint-state-publisher-system" name="gz::sim::systems::JointStatePublisher">
            <topic>joint_states</topic>
        </plugin>
        
        <!-- Joint Position Controller for steering -->
        <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
            <joint_name>base-plate-front_Revolute-14</joint_name>
            <topic>/steering/front</topic>
            <p_gain>200</p_gain>
            <i_gain>20</i_gain>
            <d_gain>0.5</d_gain>
            <effort_limit>100</effort_limit>
        </plugin>
        
        <!-- NOTE: The CAD-exported joint names "left"/"right" are physically swapped -->
        <!-- relative to the robot's actual left/right sides. We correct this by   -->
        <!-- cross-wiring: /steering/left topic → right URDF joint and vice versa. -->
        <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
            <joint_name>base-plate-right_Revolute-18</joint_name>
            <topic>/steering/left</topic>
            <p_gain>200</p_gain>
            <i_gain>20</i_gain>
            <d_gain>0.5</d_gain>
            <effort_limit>100</effort_limit>
        </plugin>
        
        <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
            <joint_name>base-plate-left_Revolute-20</joint_name>
            <topic>/steering/right</topic>
            <p_gain>200</p_gain>
            <i_gain>20</i_gain>
            <d_gain>0.5</d_gain>
            <effort_limit>100</effort_limit>
        </plugin>
        
        <!-- Joint Velocity Controller for wheel rotation (force mode with PID) -->
        <!-- Using force mode because velocity mode's DART SERVO constraint -->
        <!-- fails to overcome ground contact forces with heavy robot (136kg) -->
        <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
            <joint_name>axial-front_Revolute-10</joint_name>
            <topic>/wheel/front/velocity</topic>
            <use_force_commands>true</use_force_commands>
            <p_gain>200</p_gain>
            <i_gain>20</i_gain>
            <d_gain>0.5</d_gain>
            <i_max>100</i_max>
            <i_min>-100</i_min>
            <cmd_max>2000</cmd_max>
            <cmd_min>-2000</cmd_min>
        </plugin>
        
        <!-- NOTE: Cross-wired to match steering swap above -->
        <!-- URDF "right" joint is physically LEFT → listens on /wheel/left/velocity -->
        <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
            <joint_name>axial-right_Revolute-19</joint_name>
            <topic>/wheel/left/velocity</topic>
            <use_force_commands>true</use_force_commands>
            <p_gain>200</p_gain>
            <i_gain>20</i_gain>
            <d_gain>0.5</d_gain>
            <i_max>100</i_max>
            <i_min>-100</i_min>
            <cmd_max>2000</cmd_max>
            <cmd_min>-2000</cmd_min>
        </plugin>
        
        <!-- URDF "left" joint is physically RIGHT → listens on /wheel/right/velocity -->
        <plugin filename="gz-sim-joint-controller-system" name="gz::sim::systems::JointController">
            <joint_name>axial-left_Revolute-21</joint_name>
            <topic>/wheel/right/velocity</topic>
            <use_force_commands>true</use_force_commands>
            <p_gain>200</p_gain>
            <i_gain>20</i_gain>
            <d_gain>0.5</d_gain>
            <i_max>100</i_max>
            <i_min>-100</i_min>
            <cmd_max>2000</cmd_max>
            <cmd_min>-2000</cmd_min>
        </plugin>
        <!-- Odometry Publisher -->
        <plugin filename="gz-sim-odometry-publisher-system" name="gz::sim::systems::OdometryPublisher">
            <odom_frame>odom</odom_frame>
            <robot_base_frame>base-v1</robot_base_frame>
            <odom_topic>odom</odom_topic>
            <tf_topic>tf</tf_topic>
            <odom_publish_frequency>50</odom_publish_frequency>
        </plugin>
    </gazebo>

    <!-- Material Colors for Gazebo -->
    <gazebo reference="base-v1">
        <visual>
            <material>
                <ambient>0.2 0.2 0.8 1</ambient>
                <diffuse>0.2 0.2 0.8 1</diffuse>
            </material>
        </visual>
    </gazebo>
    
    <gazebo reference="front-wheel">
        <visual>
            <material>
                <ambient>0.1 0.1 0.1 1</ambient>
                <diffuse>0.1 0.1 0.1 1</diffuse>
            </material>
        </visual>
        <mu1>1.0</mu1>
        <mu2>1.0</mu2>
    </gazebo>
    
    <gazebo reference="left-wheel">
