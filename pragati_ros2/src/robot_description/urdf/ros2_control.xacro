<?xml version="1.0"?>
<!--
ros2_control Configuration for MG6010 Robot
Defines hardware interface and joint controllers for Gazebo simulation
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <ros2_control name="MG6010Hardware" type="system">

    <!-- Gazebo system plugin -->
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <!-- Joint 2 - Prismatic (vertical/Z-axis) -->
    <joint name="joint2">
      <command_interface name="position">
        <param name="min">0.1</param>
        <param name="max">0.32</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.2</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Joint 3 - Revolute (rotation) -->
    <joint name="joint3">
      <command_interface name="position">
        <param name="min">-1.5708</param>
        <param name="max">0.0</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Joint 4 - Prismatic (lateral/Y-axis) -->
    <joint name="joint4">
      <command_interface name="position">
        <param name="min">-0.25</param>
        <param name="max">0.35</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

    <!-- Joint 5 - Prismatic (gripper X-axis) -->
    <joint name="joint5">
      <command_interface name="position">
        <param name="min">0.0</param>
        <param name="max">0.45</param>
      </command_interface>
      <state_interface name="position">
        <param name="initial_value">0.0</param>
      </state_interface>
      <state_interface name="velocity"/>
      <state_interface name="effort"/>
    </joint>

  </ros2_control>

</robot>
